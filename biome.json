{
  "$schema": "https://biomejs.dev/schemas/2.3.7/schema.json",
  "root": true,
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "nodes/operator/app/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
      "!nodes/operator/app/src/components/reui",
      "nodes/poly/app/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
      "!nodes/poly/app/src/components/reui",
      "nodes/resy/app/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
      "!nodes/resy/app/src/components/reui",
      "nodes/node-template/app/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
      "!nodes/node-template/app/src/components/reui",
      "packages/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
      "services/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
      "tests/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
      "scripts/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
      "scripts/ci/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
      "infra/compose/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
      "*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}"
    ],
    "ignoreUnknown": false
  },
  "extends": ["./biome/base.json", "./biome/app.json", "./biome/tests.json"]
}
