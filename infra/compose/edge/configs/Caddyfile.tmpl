{
  log {
    level INFO
    format json
    output file /data/logs/caddy/caddy.log {
      roll_size 10MB
      roll_keep 7
      roll_keep_for 168h
    }
  }
}

# Redirect www to non-www (canonical domain)
www.{$DOMAIN} {
  redir https://{$DOMAIN}{uri} permanent
}

# ── Operator (primary domain) ─────────────────────────────
# Routes to k3s NodePort 30000 (operator app pod).
# Falls back to Compose app:3000 if OPERATOR_BACKEND is set (transition period).
{$DOMAIN} {
  encode zstd gzip

  # Public API namespace - rate limited, no auth required
  @public path /api/v1/public/*
  handle @public {
    reverse_proxy {$OPERATOR_BACKEND:host.docker.internal:30000} {
      header_up X-Real-IP {remote_host}
      transport http {
        response_header_timeout 10s
      }
    }
  }

  # All other requests
  reverse_proxy {$OPERATOR_BACKEND:host.docker.internal:30000}

  log {
    format json
    output file /data/logs/caddy/access.log {
      roll_size 10MB
      roll_keep 7
      roll_keep_for 168h
    }
  }
}

# ── Poly node ─────────────────────────────────────────────
poly.{$DOMAIN} {
  encode zstd gzip
  reverse_proxy host.docker.internal:30100
  log {
    format json
    output file /data/logs/caddy/poly-access.log {
      roll_size 10MB
      roll_keep 7
      roll_keep_for 168h
    }
  }
}

# ── Resy node ─────────────────────────────────────────────
resy.{$DOMAIN} {
  encode zstd gzip
  reverse_proxy host.docker.internal:30300
  log {
    format json
    output file /data/logs/caddy/resy-access.log {
      roll_size 10MB
      roll_keep 7
      roll_keep_for 168h
    }
  }
}
